DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/gurunet"
AUTH_SECRET="replace-with-a-long-random-secret"
AUTH_URL="http://localhost:3000"
AUTH_GOOGLE_ID="replace-with-google-oauth-client-id"
AUTH_GOOGLE_SECRET="replace-with-google-oauth-client-secret"
DEEPSEEK_API_KEY="replace-with-your-deepseek-api-key"
DEEPSEEK_BASE_URL="https://api.deepseek.com"
DEEPSEEK_ENABLED="true"
DEEPSEEK_FALLBACK_ONLY="false"
DEEPSEEK_FAST_MODEL="deepseek-v4-flash"
DEEPSEEK_REASONING_MODEL="deepseek-v4-pro"
AI_DAILY_CALL_LIMIT="100"
AI_USER_DAILY_CALL_LIMIT="20"
AI_DAILY_SPEND_CAP_USD="5"
AI_STRICT_CRITIQUE_ALWAYS="false"
APP_TIMEZONE="Africa/Johannesburg"
JOB_SECRET="replace-with-job-runner-secret"
IMPORT_SECRET="replace-with-json-import-secret"
GURUNET_UPLOAD_DIR=".data/uploads"
